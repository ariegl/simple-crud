generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]

  @@map("roles")
}

model User {
  id                 Int              @id @default(autoincrement())
  username           String
  age                Int
  gender             String
  password           String?          @db.VarChar(128)
  registeredDate     DateTime?        @map("registered_date")
  roleId             Int?             @map("role_id")
  deletedAt          DateTime?        @map("deleted_at")
  profileImagePath   String?          @map("profile_image_path")
  role               Role?            @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user_role")
  posts              Post[]
  likes              PostLike[]
  comments           PostComment[]
  friendshipsRequested Friendship[] @relation("requester")
  friendshipsAddressed Friendship[] @relation("addressee")
  sentMessages       PrivateMessage[] @relation("sender")
  receivedMessages   PrivateMessage[] @relation("receiver")

  @@map("users")
}

model Post {
  id          Int           @id @default(autoincrement())
  userId      Int           @map("user_id")
  post        String        @db.Text
  postedDate  DateTime?     @default(now()) @map("posted_date")
  lastUpdate  DateTime?     @default(now()) @updatedAt @map("last_update")
  deletedDate DateTime?     @map("deleted_date")
  deleted     Boolean?      @default(false)
  user        User          @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_post_user")
  likes       PostLike[]
  comments    PostComment[]

  @@map("posts")
}

model PostLike {
  id         Int       @id @default(autoincrement())
  postId     Int       @map("post_id")
  userId     Int       @map("user_id")
  actionDate DateTime? @default(now()) @map("action_date")
  deletedAt  DateTime? @map("deleted_at")
  post       Post      @relation(fields: [postId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_like_post")
  user       User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_like_user")

  @@unique([userId, postId], map: "unique_user_post_like")
  @@map("posts_likes")
}

model PostComment {
  id           Int       @id @default(autoincrement())
  postId       Int       @map("post_id")
  userId       Int       @map("user_id")
  comment      String    @db.VarChar(1000)
  registeredAt DateTime? @default(now()) @map("registered_at")
  deletedAt    DateTime? @map("deleted_at")
  post         Post      @relation(fields: [postId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_comment_post")
  user         User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_comment_user")

  @@map("posts_comments")
}

enum FriendshipStatus {
  pending
  accepted
  rejected
  blocked
}

model Friendship {
  id          Int              @id @default(autoincrement())
  requesterId Int              @map("requester_id")
  addresseeId Int              @map("addressee_id")
  status      FriendshipStatus? @default(pending)
  createdAt   DateTime?        @default(now()) @map("created_at")
  updatedAt   DateTime?        @default(now()) @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  requester   User             @relation("requester", fields: [requesterId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_friend_requester")
  addressee   User             @relation("addressee", fields: [addresseeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_friend_addressee")

  @@unique([requesterId, addresseeId], map: "unique_friendship")
  @@map("friendships")
}

model PrivateMessage {
  id               String    @id @db.Char(36)
  senderId         Int       @map("sender_id")
  receiverId       Int       @map("receiver_id")
  message          String    @db.Text
  readAt           DateTime? @map("read_at")
  deletedBySender  DateTime? @map("deleted_by_sender")
  deletedByReceiver DateTime? @map("deleted_by_receiver")
  createdAt        DateTime? @default(now()) @map("created_at")
  sender           User      @relation("sender", fields: [senderId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_msg_sender")
  receiver         User      @relation("receiver", fields: [receiverId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_msg_receiver")

  @@map("private_messages")
}
